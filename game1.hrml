<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Adaptive Puzzle Game</title>
<style>
  body { margin:0; overflow:hidden; background:#111; }
  canvas { display:block; }

  .controls {
    position:fixed;
    bottom:10px;
    left:50%;
    transform:translateX(-50%);
    display:flex;
    gap:10px;
  }

  button {
    width:60px;
    height:60px;
    font-size:20px;
    border:none;
    border-radius:10px;
    background:#333;
    color:white;
  }

  #rulesBtn {
    position:fixed;
    top:10px;
    right:10px;
    width:auto;
    padding:10px;
  }

  #modal {
    position:fixed;
    top:0; left:0;
    width:100%; height:100%;
    background:rgba(0,0,0,0.7);
    display:none;
    justify-content:center;
    align-items:center;
  }

  #modalContent {
    background:#222;
    color:white;
    padding:20px;
    border-radius:10px;
    max-width:90%;
  }
</style>
</head>
<body>

<canvas id="game"></canvas>

<button id="rulesBtn" onclick="toggleRules()">📜 Правила</button>

<div id="modal">
  <div id="modalContent">
    <h3>Правила игры</h3>
    <p>
    🎮 Цель: собрать все ключи.<br><br>
    ⬅️➡️ — движение<br>
    ⬆️ — прыжок вверх<br>
    ⏩ — прыжок вперёд на 3 клетки<br><br>

    🔺 Шипы:<br>
    🔴 всегда опасны<br>
    🟣 опасны в розовый ход<br>
    🔵 опасны в синий ход<br><br>

    🔫 Пушки стреляют в свой ход<br><br>

    🟢 Толкатели двигают тебя на 3 клетки<br>
    🟣 Меняют гравитацию (пол ↔ потолок)<br><br>

    ❗ Каждый ход = движение игрока<br>
    ❗ Любое касание опасности = поражение
    </p>
    <button onclick="toggleRules()">Закрыть</button>
  </div>
</div>

<div class="controls">
  <button onclick="move(-1,0)">⬅️</button>
  <button onclick="move(1,0)">➡️</button>
  <button onclick="move(0,-1*player.gravity)">⬆️</button>
  <button onclick="move(3,0)">⏩</button>
</div>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

let TILE = 40;
let scale = 1;
let paused = false;

const W = 40;
const H = 15;

let camX = 0;
let phase = 0;

let level = [
"########################################",
"#..............K...............B.......#",
"#..^..p..b..###...........>............#",
"#..............^.......................#",
"#....G.................P...............#",
"#.............###......................#",
"#..K...................^...............#",
"#...............B......................#",
"#.....^.........................K......#",
"#.....................................#",
"#.....................................#",
"#.....................................#",
"#.....................................#",
"#.....................................#",
"########################################"
];

let player = {x:2,y:10,gravity:1};
let keys = 0;
let bullets = [];

function toggleRules(){
  let modal = document.getElementById("modal");
  paused = !paused;
  modal.style.display = paused ? "flex" : "none";
}

function resize(){
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  scale = Math.min(
    canvas.width / (20*TILE),
    canvas.height / (10*TILE)
  );
}
window.addEventListener("resize", resize);
resize();

function draw(){
  if(paused) return;

  ctx.setTransform(scale,0,0,scale,0,0);
  ctx.clearRect(0,0,canvas.width,canvas.height);

  camX = player.x*TILE - (canvas.width/scale)/2;
  camX = Math.max(0, Math.min(camX, W*TILE - canvas.width/scale));

  ctx.save();
  ctx.translate(-camX,0);

  for(let y=0;y<H;y++){
    for(let x=0;x<W;x++){
      let t = level[y][x];
      let px = x*TILE;
      let py = y*TILE;

      if(t==="#"){
        ctx.fillStyle="#555";
        ctx.fillRect(px,py,TILE,TILE);
      }

      if(t==="^") drawTriangle(px,py,"red");
      if(t==="p") drawTriangle(px,py, phase===0?"pink":"#333");
      if(t==="b") drawTriangle(px,py, phase===1?"cyan":"#333");

      if(t==="K"){
        ctx.fillStyle="gold";
        ctx.fillRect(px+12,py+12,16,16);
      }

      if(t==="G"){
        drawCircle(px,py,"lime");
        drawArrow(px,py);
      }

      if(t==="P"){
        drawCircle(px,py,"purple");
      }

      if(t==="B"){
        drawCannon(px,py,"cyan");
      }
    }
  }

  bullets.forEach(b=>{
    ctx.fillStyle=b.color;
    ctx.beginPath();
    ctx.arc(b.x*TILE+20,b.y*TILE+20,6,0,Math.PI*2);
    ctx.fill();
  });

  ctx.fillStyle="white";
  ctx.fillRect(player.x*TILE+10,player.y*TILE+10,20,20);

  ctx.restore();

  ctx.fillStyle="white";
  ctx.fillText("Фаза: "+(phase===0?"РОЗОВАЯ":"СИНЯЯ")+" | Ключи: "+keys,10,20);
}

function drawTriangle(x,y,color){
  ctx.fillStyle=color;
  ctx.beginPath();
  ctx.moveTo(x+TILE/2,y+8);
  ctx.lineTo(x+8,y+TILE-8);
  ctx.lineTo(x+TILE-8,y+TILE-8);
  ctx.closePath();
  ctx.fill();
}

function drawCircle(x,y,color){
  ctx.fillStyle=color;
  ctx.beginPath();
  ctx.arc(x+TILE/2,y+TILE/2,12,0,Math.PI*2);
  ctx.fill();
}

function drawArrow(x,y){
  ctx.strokeStyle="black";
  ctx.lineWidth=3;
  ctx.beginPath();
  ctx.moveTo(x+10,y+20);
  ctx.lineTo(x+30,y+20);
  ctx.lineTo(x+25,y+15);
  ctx.moveTo(x+30,y+20);
  ctx.lineTo(x+25,y+25);
  ctx.stroke();
}

function drawCannon(x,y,color){
  ctx.fillStyle="#444";
  ctx.fillRect(x+5,y+10,30,20);
  ctx.fillStyle=color;
  ctx.fillRect(x+25,y+15,10,10);
}

function isSolid(x,y){
  return level[y][x] === "#";
}

function move(dx,dy){
  if(paused) return;

  let nx = player.x + dx;
  let ny = player.y + dy;

  if(isSolid(nx,ny)) return;

  player.x = nx;
  player.y = ny;

  interact();
  nextTurn();
}

function interact(){
  let t = level[player.y][player.x];

  if(t==="^") die();
  if(t==="p" && phase===0) die();
  if(t==="b" && phase===1) die();

  if(t==="K"){
    keys++;
    level[player.y] =
      level[player.y].substring(0,player.x)+"."+level[player.y].substring(player.x+1);
  }

  if(t==="G"){ move(3,0); }
  if(t==="P"){ player.gravity *= -1; }

  bullets.forEach(b=>{
    if(b.x===player.x && b.y===player.y) die();
  });
}

function nextTurn(){
  phase = 1 - phase;

  for(let y=0;y<H;y++){
    for(let x=0;x<W;x++){
      let t = level[y][x];
      if(t==="B" && phase===1){
        bullets.push({x:x-1,y:y,dx:-1,color:"cyan"});
      }
    }
  }

  bullets.forEach(b=> b.x += b.dx);
  bullets = bullets.filter(b=> b.x>=0);

  bullets.forEach(b=>{
    if(b.x===player.x && b.y===player.y) die();
  });

  if(keys>=3){
    alert("Победа!");
    location.reload();
  }
}

function die(){
  alert("Проигрыш!");
  location.reload();
}

document.addEventListener("keydown",e=>{
  if(paused) return;

  if(e.key==="ArrowRight") move(1,0);
  if(e.key==="ArrowLeft") move(-1,0);
  if(e.key==="ArrowUp") move(0,-1*player.gravity);
  if(e.key===" ") move(3,0);
});

setInterval(draw,100);
</script>
</body>
</html>
